{
  "name": "bugbundle-workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --recursive build",
    "check": "pnpm build && pnpm typecheck && pnpm test",
    "test": "vitest run",
    "typecheck": "pnpm --filter @bugbundle/core build && pnpm --recursive typecheck"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.0.0"
  }
}

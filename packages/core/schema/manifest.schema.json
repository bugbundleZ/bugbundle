{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bugbundle.dev/schema/manifest-v1.json",
  "title": "BugBundle manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "command",
    "result",
    "runtime",
    "artifacts",
    "files",
    "redactions",
    "truncated"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exitCode", "signal"],
      "properties": {
        "exitCode": { "type": ["integer", "null"] },
        "signal": { "type": ["string", "null"] }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "platform", "arch"],
      "properties": {
        "node": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "minLength": 1 },
        "arch": { "type": "string", "minLength": 1 }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stdout", "stderr"],
      "properties": {
        "stdout": { "const": "logs/stdout.log" },
        "stderr": { "const": "logs/stderr.log" }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "bytes", "sha256", "kind"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "kind": { "enum": ["log", "project"] }
        }
      }
    },
    "redactions": { "type": "integer", "minimum": 0 },
    "truncated": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stdout", "stderr"],
      "properties": {
        "stdout": { "type": "boolean" },
        "stderr": { "type": "boolean" }
      }
    }
  }
}

{
  "name": "@bugbundle/core",
  "version": "0.3.0",
  "description": "Deterministic, privacy-aware bug reproduction bundle primitives",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bugbundleZ/bugbundle.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/bugbundleZ/bugbundle#readme",
  "bugs": {
    "url": "https://github.com/bugbundleZ/bugbundle/issues"
  },
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./manifest.schema.json": "./schema/manifest.schema.json"
  },
  "files": [
    "dist",
    "schema",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "fast-glob": "^3.3.3",
    "fflate": "^0.8.2",
    "yaml": "^2.8.0"
  }
}
